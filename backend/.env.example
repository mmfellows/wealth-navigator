# Server Configuration
PORT=3001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# Free Financial Data APIs (choose one)
# Alpha Vantage (free: 5 calls/min, 500 calls/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# IEX Cloud (generous free tier)
IEX_CLOUD_TOKEN=your_iex_token

# Yahoo Finance API (free but unofficial - no key needed)
USE_YAHOO_FINANCE=true

# AI Research Assistant (optional)
# OpenAI (pay per use)
OPENAI_API_KEY=your_openai_key

# Perplexity (has free tier)
PERPLEXITY_API_KEY=your_perplexity_key

# Plaid Configuration (for brokerage account connections)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_key
PLAID_ENV=sandbox  # sandbox, development, or production
PLAID_REDIRECT_URI=http://localhost:3000/oauth-callback

# Brokerage APIs (when ready to connect)
ETRADE_CONSUMER_KEY=your_etrade_key
ETRADE_CONSUMER_SECRET=your_etrade_secret
SCHWAB_CLIENT_ID=your_schwab_id
SCHWAB_CLIENT_SECRET=your_schwab_secret